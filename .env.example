# Copy this to .env and fill in your values

# Anthropic API key (required)
ANTHROPIC_API_KEY=""

# Model used for the agent being evaluated
AGENT_MODEL=claude-opus-4-6

# Model used for LLM-as-judge graders (can differ from agent model)
JUDGE_MODEL=claude-sonnet-4-5

# How many concurrent tasks to run in the eval harness
EVAL_CONCURRENCY=5

# Where to persist eval results 
RESULTS_DIR=results
